
user_name=$(whoami)
save_creation_param user_name $user_name

user_id=$(grep "^${user_name}:" /etc/passwd | sed -E "s/.*:([0-9]+:[0-9]+):.*/\1/")
group_id=$(echo $user_id | sed -e "s/.*://")
save_creation_param group_id $group_id
user_id=$(echo $user_id | sed -e "s/:.*//")
save_creation_param user_id $user_id
