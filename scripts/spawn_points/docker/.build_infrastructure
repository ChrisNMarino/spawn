
echo Building docker container \"$instance_name\" from \"$docker_distro\"

workingdir=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

machine_dir=$(get_machine_dir)

cp $(get_machine_dir)/.config .build_config
rm .build_config

docker build \
    --build-arg DISTRO=$docker_distro \
    --build-arg INIT_SCRIPT="scripts/system_setup ${spawn_point} ${spawn_config} ${instance_name} ${user_name} ${user_id} ${group_id}" \
    -f ${workingdir}/Dockerfile -t $instance_name .
