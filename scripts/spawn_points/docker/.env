
docker_distro_options=rockylinux:9,almalinux:9,oraclelinux:9,ubuntu:latest

if command -v docker >/dev/null; then
    running_docker_instances=$(docker ps --format table | grep -v "CONTAINER ID" | awk '{ print $2 }' 2>/dev/null)
    current_docker_images=$(docker image ls --format table | awk '{print $1}' | grep -v ^IMAGE$ 2>/dev/null)
fi