home_dir=$HOME/.spawn/machines/docker_${instance_name}/home
user_id=$(docker run ${instance_name} grep "^${user_name}:" /etc/passwd | sed -E "s/.*:([0-9]+:[0-9]+):.*/\1/")
sudo chown -R $(whoami):$(whoami) $home_dir 
mkdir -p $home_dir/builder
cp $(get_machine_dir)/.config .build_config
tar -cf $home_dir/builder/builder.tar .
rm .build_config
pushd $home_dir/builder/ > /dev/null
    tar -xf builder.tar
popd > /dev/null

docker run -it \
    -v $home_dir:/home/${user_name} \
    -u $user_id \
    ${instance_name} \
    /home/${user_name}/builder/scripts/user_setup ${spawn_config} ${spawn_point}

sudo rm -rf $home_dir/builder.tar $home_dir/builder

