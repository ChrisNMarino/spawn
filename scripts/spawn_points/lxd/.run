
lxc config set ${instance_name} security.privileged true
lxc config set ${instance_name} security.nesting true

lxc config device add $instance_name host_home disk path=/home/${user_name}/home source=${HOME} 2>/dev/null
lxc config device add $instance_name docker_storage disk path=/var/lib/docker source=${HOME}/.spawn/machines/$machine/docker_storage 2>/dev/null
lxc config device add $instance_name host_root disk path=/mnt/host_root source=/ 2>/dev/null
lxc config device set $instance_name host_root recursive true 2>/dev/null

if ! lxc ls | grep -q .*${instance_name}.*RUNNING.*CONTAINER; then
    lxc start ${instance_name}
fi
user_id=$(lxc exec ${instance_name} -- grep "^${user_name}:" /etc/passwd | sed -E "s/.*:([0-9]+:[0-9]+):.*/\1/")
group_id=$(echo $user_id | sed -e "s/.*://")
user_id=$(echo $user_id | sed -e "s/:.*//")
if [ "" == "${user_id}" ] || [ "" == "${group_id}" ]; then
    echo "Problem getting user_id(${user_id}) and group_id(${group_id})"
    exit
fi

lxc config device add $instance_name mygpu gpu 2>/dev/null

xhost +local:

lxc exec ${instance_name} \
    --user ${user_id} --group ${group_id} \
    -- sudo \
        HOME=/home/${user_name} \
        DISPLAY=${DISPLAY} \
        WAYLAND_DISPLAY=${WAYLAND_DISPLAY} \
        XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR} \
        PULSE_SERVER=unix:${XDG_RUNTIME_DIR}/pulse/native \
        XAUTHORITY=${XAUTHORITY} \
        su ${user_name} -P -c "bash -l"