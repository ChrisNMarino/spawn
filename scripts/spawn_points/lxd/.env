lxc_distro_options=images:rockylinux/9/amd64,images:almalinux/9/amd64,images:oracle/9/amd64,ubuntu:26.04

if command -v lxc >/dev/null 2>&1; then
    running_lxd_instances=$(lxc ls | grep RUNNING | sed -e "s/|//g" | awk '{ print $1 }' 2>/dev/null)
    current_lxd_images=$(lxc ls | grep CONTAINER | sed -e "s/|//g" | awk '{print $1}' 2>/dev/null)
fi