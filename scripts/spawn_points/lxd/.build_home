cp $(get_machine_dir)/.config .build_config
tar -czf ~/spawn.tar.gz .
rm .build_config
lxc file push ~/spawn.tar.gz $instance_name/home/${user_name}/
rm ~/spawn.tar.gz
lxc exec $instance_name -- chown ${user_name}:${user_name} /home/${user_name}/spawn.tar.gz
user_id=$(lxc exec ${instance_name} -- grep "^${user_name}:" /etc/passwd | sed -E "s/.*:([0-9]+:[0-9]+):.*/\1/")
group_id=$(echo $user_id | sed -e "s/.*://")
user_id=$(echo $user_id | sed -e "s/:.*//")

lxd_cmd="
    mkdir ~/builder;
    pushd ~/builder > /dev/null;
        tar -xzf ~/spawn.tar.gz;
        rm ~/spawn.tar.gz;
        scripts/user_setup ${spawn_config} ${spawn_point};
        echo cat '$(cat ~/.ssh/*.pub)' >> ~/.ssh/authorized_keys;
        pushd ~;
        pwd;
        ls;
        popd;
    popd > /dev/null;
    rm -rf ~/builder;
"
lxc exec $instance_name --user $user_id --group $group_id --env HOME=/home/${user_name} -- bash -lc "${lxd_cmd}"
