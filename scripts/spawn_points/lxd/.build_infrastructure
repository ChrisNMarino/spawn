
machine_dir=$(get_machine_dir)

echo "user_name=${user_name}" >> ${machine_dir}/.config

if ! grep -q "root:$UID:1" /etc/subuid; then
    echo "root:${UID}:1" | sudo tee -a /etc/subuid /etc/subgid
fi

lxc stop $instance_name 2>/dev/null
lxc delete $instance_name 2>/dev/null
lxc launch $lxc_distro $instance_name -c security.privileged=true

cp $(get_machine_dir)/.config .build_config
pushd .. > /dev/null
    tar -czf ~/spawn.tar.gz spawn
popd > /dev/null
rm .build_config

lxc file push ~/spawn.tar.gz $instance_name/

rm ~/spawn.tar.gz

lxd_cmd="
    pushd / > /dev/null;
		yum install -y -q tar 2> /dev/null;
		apt install -y -q tar 2> /dev/null;
        tar -xzf spawn.tar.gz;
        pushd spawn > /dev/null;
            scripts/system_setup ${spawn_point} ${spawn_config} ${instance_name} ${user_name} ${user_id} ${group_id};
        popd > /dev/null;
        rm -rf /spawn;
		rm /spawn.tar.gz;
    popd > /dev/null
"
lxc exec $instance_name -- bash -lc "${lxd_cmd}"

