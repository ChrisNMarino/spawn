WINHOME=$(wslpath $(cmd.exe /c echo %USERPROFILE% | sed -e "s/\r//"))

cp $(get_machine_dir)/.config .build_config
tar -czf ${WINHOME}/spawn.tar.gz .
rm .build_config

wsl_cmd="
    mkdir ~/builder;
    pushd ~/builder > /dev/null;
        tar -xzf ${WINHOME}/spawn.tar.gz;
        scripts/user_setup ${spawn_config} ${spawn_point};
    popd > /dev/null;
    rm -rf ~/builder;
"
wsl.exe -d ${instance_name} -u ${user_name} -e bash -lc "${wsl_cmd}"

rm ${WINHOME}/spawn.tar.gz

