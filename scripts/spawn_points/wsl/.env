if [ -f /mnt/c/Windows/system32/wsl.exe ]; then
    running_wsl_instances=$(/mnt/c/Windows/system32/wsl.exe -l --running | iconv -f utf-16le -t utf-8 | sed -e "s/\r//" | grep -v "Distributions:" | sed -e "s/(Default)//")
    current_wsl_images=$(/mnt/c/Windows/system32/wsl.exe -l | iconv -f utf-16le -t utf-8 | sed -e "s/\r//" | grep -v "Distributions:" | sed -e "s/(Default)//")
fi