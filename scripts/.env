for i in $(ls $(cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" && pwd)/spawn_points/*/.env); do
    . $i
done

function user_prompt() {
    declare -n user_input=$1
    while [ "" == "$user_input" ]; do
        echo
        echo $2
        read -p "> " user_input
        if [ $user_input == "" ]; then
            echo
            echo Invalid input. try again
        fi
    done
}

function user_select() {
    declare -n ref=$1

    if [ "" != "$ref" ]; then
        # already had user_input
        valid=false
        index=3
        while [ $index -lt $(($# + 1)) ]; do
            if [ "${!index}" == "${ref}" ]; then
                valid=true
            fi
            index=$(( index + 1 ))
        done
        if [ false == $valid ]; then
            echo \"$ref\" is not valid for $1
            exit
        fi
    fi

    while [ "" == "$ref" ]; do
        echo
        echo $2
        choice_index=-1
        for option in "$@"; do
            if (( choice_index > 0 )); then
                echo ${choice_index}: $option
            fi
            choice_index=$((choice_index + 1))
        done
        read -p "> " user_input
        if [[ $user_input -gt 0 && $user_input -lt choice_index ]]; then
            user_input=$((user_input+2))
            ref="${!user_input}"
        else
            echo
            echo Invalid input. try again
            user_input=""
        fi
    done
}

function src_or_fail() {
    echo
    echo Run: $1
    if [ ! -f $1 ]; then
        echo Unable to locate $1
        exit
    fi
    . $1
    echo Finished: $1
    echo
}

_build_order_recurse() {
    if [ -f spawn_configs/$1/depends ]; then
        local i
        for i in $(cat spawn_configs/$1/depends); do
            build_order $i
            echo $i
        done
    fi
}
build_order() {
    result=""
    local i
    for i in $(_build_order_recurse $1); do
        if ! $(echo "$result" | grep -q "$i"); then
            result="${result}${i} "
        fi
    done
    echo ${result}${1}
}

exists_in_list() {
    local i
    for i in $2; do
        if [ "$1" == "$i" ]; then
            return 0
        fi
    done
    return 1
}

show_status_all() {
    local machine_name
    local instance_name
    local spawn_point
    local user_name
    local status

    mkdir -p ~/.spawn/machines
    if $(ls ~/.spawn/machines/* >/dev/null 2>&1); then 
        printf "%-20s %-12s %-12s\n" "InstanceName" "SpawnPoint" "Status"
        echo =============================================================
        for machine_name in $(ls ~/.spawn/machines); do
            . ~/.spawn/machines/${machine_name}/.config
            running_instances=running_${spawn_point}_instances
            if exists_in_list $instance_name "${!running_instances}"; then
                status="RUNNING"
            else
                status="STOPPED"
            fi
            current_images=current_${spawn_point}_images
            if ! exists_in_list $instance_name "${!current_images}"; then
                status="MISSING"
            fi
            printf "%-20s %-12s %-12s\n" "${instance_name}" "${spawn_point}" "${status}"
        done
        echo =============================================================
    fi
}